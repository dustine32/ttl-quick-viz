# Copy to .env for local dev.
# GRAPHS_DIR is required — the API fails to start without it.

GRAPHS_DIR=../conversion/downloads/output

# Optional. Directory the api can re-run ttl2json on.
# Needed for POST /api/convert, POST /api/graphs/{id}/rebuild, and the file watcher.
INPUT_DIR=../conversion/downloads/input

# When true AND INPUT_DIR is set, the api starts a watchdog thread
# that auto-reconverts on .ttl change. Dev only.
ENABLE_WATCHER=false

# Per-file debounce window for the watcher (ms). Editors often
# write the same file multiple times per save.
WATCHER_DEBOUNCE_MS=2000

HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
